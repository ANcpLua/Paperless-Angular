{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "Changelog",
        "CI",
        "Clean",
        "Compile",
        "Coverage",
        "Dev",
        "DockerBuildRest",
        "DockerBuildServices",
        "DockerDown",
        "DockerImageBuild",
        "DockerImagePush",
        "DockerLogs",
        "DockerPull",
        "DockerRestart",
        "DockerStatus",
        "DockerUp",
        "IntegrationTests",
        "Print",
        "ReportCoverage",
        "Restore",
        "Test",
        "UnitTests",
        "Verify"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "Configuration": {
          "type": "string",
          "description": "Build configuration (Debug/Release)",
          "enum": [
            "Debug",
            "Release"
          ]
        },
        "CoverageExcludeGeneratedParam": {
          "type": "string",
          "description": "Exclude generated files, migrations, state machines"
        },
        "CoverageFormat": {
          "type": "string",
          "description": "Output format: table, json, markdown"
        },
        "CoverageMinBranch": {
          "type": "string",
          "description": "Minimum branch coverage percentage"
        },
        "CoverageMinLine": {
          "type": "string",
          "description": "Minimum line coverage percentage"
        },
        "IDockerBuildImageTag": {
          "type": "string",
          "description": "Docker image tag"
        },
        "IDockerBuildPush": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Push images after build"
        },
        "IDockerBuildRegistry": {
          "type": "string",
          "description": "Docker registry prefix"
        },
        "IDockerComposeDockerBuild": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Build images before starting (--build)"
        },
        "IDockerComposeForceRecreate": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Force recreate containers (--force-recreate)"
        },
        "IDockerComposeLogTail": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of log lines to tail",
          "format": "int32"
        },
        "IDockerComposeRemoveVolumes": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Remove volumes on down (-v)"
        },
        "IDockerComposeService": {
          "type": "string",
          "description": "Target specific service"
        },
        "ITestLiveOutput": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Show live test output"
        },
        "ITestStopOnFail": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Stop on first test failure"
        },
        "ITestTestFilter": {
          "type": "string",
          "description": "Test filter expression (xUnit v3 query syntax)"
        },
        "Solution": {
          "type": "string",
          "description": "Path to a solution file that is automatically loaded"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
